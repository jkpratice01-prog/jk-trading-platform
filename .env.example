# AlphaVantage API Key — get free key at: https://www.alphavantage.co/
VITE_ALPHA_VANTAGE_API_KEY=your_api_key_here

# Alpaca Market Data — free options chain data with greeks + IV
# Free signup: https://alpaca.markets → Paper Trading → API Keys
# VITE_ALPACA_FEED: "indicative" (free) or "opra" (real-time, $99/mo plan)
VITE_ALPACA_KEY_ID=your_alpaca_key_id
VITE_ALPACA_SECRET_KEY=your_alpaca_secret_key
VITE_ALPACA_FEED=indicative

# Tradier API key — alternative source for real options chain data
# Free signup: https://tradier.com/products/markets/data-api
VITE_TRADIER_TOKEN=your_tradier_token_here

